{
  "name": "seim-frontend-build",
  "version": "1.0.0",
  "description": "Frontend build tooling for SEIM (Django)",
  "scripts": {
    "build": "set LOG_LEVEL=ERROR && webpack --mode production",
    "build:dev": "set LOG_LEVEL=DEBUG && webpack --mode development",
    "build:analyze": "set ANALYZE=true && set LOG_LEVEL=ERROR && webpack --mode production",
    "postbuild": "python scripts/update_static_references.py",
    "dev": "set LOG_LEVEL=DEBUG && webpack --mode development --watch",
    "dev:hot": "set LOG_LEVEL=DEBUG && webpack serve --mode development",
    "optimize:css": "python scripts/optimize_css.py",
    "optimize:all": "npm run optimize:css && npm run build",
    "test": "jest --config jest.config.frontend.js",
    "test:watch": "jest --config jest.config.frontend.js --watch",
    "test:coverage": "jest --config jest.config.frontend.js --coverage",
    "test:unit": "jest --config jest.config.frontend.js --testPathPattern=tests/frontend/unit",
    "test:integration": "jest --config jest.config.frontend.js --testPathPattern=tests/frontend/integration",
    "test:e2e": "jest --config jest.config.frontend.js --testPathPattern=tests/frontend/e2e",
    "test:debug": "jest --config jest.config.frontend.js --runInBand --detectOpenHandles",
    "test:ci": "jest --config jest.config.frontend.js --ci --coverage --watchAll=false",
    "lint": "eslint static/js/**/*.js --config .eslintrc.js",
    "lint:fix": "eslint static/js/**/*.js --config .eslintrc.js --fix",
    "format": "prettier --write static/js/**/*.js",
    "format:check": "prettier --check static/js/**/*.js",
    "quality": "node scripts/code-quality-analyzer.js",
    "quality:detailed": "node scripts/code-quality-analyzer.js --detailed",
    "quality:strict": "node scripts/code-quality-analyzer.js --fail-on-issues",
    "quality:all": "npm run lint && npm run format:check && npm run quality:strict",
    "maintenance": "node scripts/maintenance-automation.js",
    "maintenance:force": "node scripts/maintenance-automation.js --force",
    "maintenance:security": "node scripts/maintenance-automation.js --skip-dependencies --skip-performance --skip-cleanup",
    "monitoring:start": "node scripts/monitoring-system.js --start",
    "monitoring:stop": "node scripts/monitoring-system.js --stop",
    "monitoring:report": "node scripts/monitoring-system.js --report",
    "monitoring:stats": "node scripts/monitoring-system.js --stats",
    "monitoring:cleanup": "node scripts/monitoring-system.js --cleanup",
    "maintenance:all": "npm run maintenance && npm run monitoring:report"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "babel-loader": "^9.1.3",
    "clean-webpack-plugin": "^4.0.0",
    "compression-webpack-plugin": "^10.0.0",
    "css-loader": "^6.10.0",
    "css-minimizer-webpack-plugin": "^5.0.0",
    "mini-css-extract-plugin": "^2.7.6",
    "terser-webpack-plugin": "^5.3.0",
    "webpack": "^5.100.0",
    "webpack-bundle-analyzer": "^4.9.0",
    "webpack-cli": "^5.1.4",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/user-event": "^14.5.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-junit": "^16.0.0",
    "jest-serializer-html": "^7.1.0",
    "jest-watch-typeahead": "^2.2.2",
    "jsdom": "^24.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsdoc": "^48.2.1",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-security": "^2.1.1",
    "eslint-plugin-unicorn": "^54.0.0",
    "prettier": "^3.2.5"
  },
  "dependencies": {
    "sweetalert2": "^11.22.2"
  }
}
