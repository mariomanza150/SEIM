# Production Environment Variables
# Django API Base URL (same origin in production)
VITE_API_BASE_URL=

# WebSocket URL for Django Channels
VITE_WS_BASE_URL=wss://your-domain.com

# App Configuration
VITE_APP_NAME=SEIM
VITE_APP_VERSION=2.0.0-vue

# Debug Mode
VITE_DEBUG=false

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_SENTRY=true
