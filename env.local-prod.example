# SEIM local production (docker-compose.local-prod.yml)
#
# 1. Copy this file to .env.local-prod (gitignored) and replace placeholders.
# 2. Start with Compose interpolation + container env (full stack recommended):
#    docker compose -f docker-compose.local-prod.yml --env-file .env.local-prod up -d --build
#    Orphans from other compose projects: add --remove-orphans once if Compose warns.
#
# Troubleshooting: ``could not translate host name "db"`` means the container is not on the
# Compose network (e.g. ``docker run`` without ``--network``, or ``docker compose run --no-deps``).
# Start the full stack so the ``db`` service exists and DNS resolves.
#
# The compose file still sets DATABASE_URL, Redis/Celery URLs, CORS/CSRF for
# localhost:8020 and :8021 on the web service (both map to the app); this file mainly supplies secrets and
# settings that are not duplicated there (AWS, Gmail SMTP, etc.).

# --- Used by Compose ${...} substitution (db/redis passwords, Django secret) ---
SECRET_KEY=your-secret-key-change-me
DB_PASSWORD=changeme123
REDIS_PASSWORD=redis123

# --- Required by seim.settings.production (S3) ---
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name

# --- Gmail SMTP (use a Google "App Password" with 2FA; not your normal password) ---
# Set DEFAULT_FROM_EMAIL to the same address as EMAIL_HOST_USER so Gmail accepts the sender.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# --- Optional: align with dev env.example ---
VIRUS_SCANNER_TYPE=mock
AGREEMENT_EXPIRATION_REMINDER_DAYS=90,30,7

WEBSOCKET_ENABLED=True
WEBSOCKET_RECONNECT_INTERVAL=5000
FEATURE_WEBSOCKET_NOTIFICATIONS=True
FEATURE_ADVANCED_SEARCH=True
FEATURE_CALENDAR_VIEW=True
FEATURE_NOTIFICATION_CENTER=True
