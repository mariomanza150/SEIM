# SEIM Production Environment Configuration
# Copy this file to .env.prod and fill in your actual values
# Use Docker secrets for sensitive values (see deployment guide)

# Django Configuration
DJANGO_ENV=production
DEBUG=false
# SECRET_KEY will be read from Docker secrets file
ALLOWED_HOSTS=your-domain.com,www.your-domain.com,api.your-domain.com,localhost

# CORS Configuration (CRITICAL: Set these for production security!)
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com,https://app.your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com,https://app.your-domain.com

# Database Configuration
POSTGRES_DB=seim
POSTGRES_USER=seimuser
# POSTGRES_PASSWORD will be read from Docker secrets file

# Redis Configuration
# REDIS_PASSWORD will be read from Docker secrets file

# Gunicorn Configuration
GUNICORN_WORKERS=3
GUNICORN_WORKER_CLASS=sync
GUNICORN_WORKER_CONNECTIONS=1000
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100
GUNICORN_TIMEOUT=30
GUNICORN_KEEP_ALIVE=2
GUNICORN_LOG_LEVEL=info

# Celery Configuration
CELERY_CONCURRENCY=4
CELERY_REPLICAS=2

# Scaling Configuration
WEB_REPLICAS=2

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
# EMAIL_HOST_USER will be read from Docker secrets file
# EMAIL_HOST_PASSWORD will be read from Docker secrets file
DEFAULT_FROM_EMAIL=noreply@your-domain.com

# AWS Configuration (if using S3 for file storage)
AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name
# AWS_ACCESS_KEY_ID will be read from Docker secrets file
# AWS_SECRET_ACCESS_KEY will be read from Docker secrets file

# Virus Scanner Configuration
VIRUS_SCANNER_TYPE=clamav
VIRUS_SCANNER_HOST=clamav
VIRUS_SCANNER_PORT=3310
VIRUS_SCANNER_TIMEOUT=30
VIRUS_SCAN_FAIL_SECURE=true

# Logging Configuration
LOG_LEVEL=INFO

# Security Configuration
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true
CSRF_COOKIE_SECURE=true
SESSION_COOKIE_SECURE=true

# Performance Configuration
CACHE_TIMEOUT=300
SESSION_COOKIE_AGE=3600

# Monitoring Configuration (optional)
ENABLE_MONITORING=false
MONITORING_ENDPOINT=http://monitoring:9090
