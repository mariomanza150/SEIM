# SEIM Environment Configuration
# Copy this file to .env and fill in your actual values

# Django Configuration
DJANGO_ENV=dev  # dev or production
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Configuration
# For Docker development, use the service name 'db' as host
DATABASE_URL=postgresql://seimuser:seimpass@db:5432/seim
# Host port published by docker-compose.yml (db:5434->5432). Used when SEIM rewrites
# ``db`` to 127.0.0.1 for manage.py/runserver on the host OS (development and production settings).
# DATABASE_PUBLISHED_PORT=5434
# For local development without Docker, use localhost
# DATABASE_URL=postgresql://user:password@localhost:5432/seim_db

# Redis Configuration
# For Docker development, use the service name 'redis' as host
REDIS_URL=redis://redis:6379/0
# For local development without Docker, use localhost
# REDIS_URL=redis://localhost:6379/0

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For SMTP: django.core.mail.backends.smtp.EmailBackend
# For AWS SES: django_ses.SESBackend

# SMTP Settings (if using SMTP; Gmail: use an App Password with 2FA enabled)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
# For Gmail SMTP, use the same address as EMAIL_HOST_USER (Gmail expects the authenticated sender).
DEFAULT_FROM_EMAIL=your-email@gmail.com

# AWS SES Settings (if using AWS SES)
AWS_SES_REGION_NAME=us-east-1
AWS_SES_ACCESS_KEY_ID=your-aws-access-key
AWS_SES_SECRET_ACCESS_KEY=your-aws-secret-key

# AWS S3 Settings (for file storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name

# Exchange agreements: comma-separated days-before-end_date to notify staff (admins + coordinators)
AGREEMENT_EXPIRATION_REMINDER_DAYS=90,30,7
# Optional: which agreement statuses are included (default active,renewal_pending)
# AGREEMENT_EXPIRATION_REMINDER_STATUSES=active,renewal_pending

# Celery Configuration
# For Docker development, use the service name 'redis' as host
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
# For local development without Docker, use localhost
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Virus Scanner Configuration
# Options: clamav, clamav_cli, mock
VIRUS_SCANNER_TYPE=mock
# For Docker with ClamAV service
# VIRUS_SCANNER_TYPE=clamav
# VIRUS_SCANNER_HOST=clamav
# VIRUS_SCANNER_PORT=3310
# For local ClamAV daemon
# VIRUS_SCANNER_TYPE=clamav
# VIRUS_SCANNER_HOST=localhost
# VIRUS_SCANNER_PORT=3310
# VIRUS_SCANNER_SOCKET_PATH=/var/run/clamav/clamd.ctl
VIRUS_SCANNER_TIMEOUT=30
VIRUS_SCANNER_CLAMSCAN_PATH=clamscan
VIRUS_SCAN_FAIL_SECURE=true

# Development/Testing only
VIRUS_SCANNER_SIMULATE_INFECTED=false
VIRUS_SCANNER_THREAT_NAME=TestVirus

# WebSocket Configuration (Phase 2)
WEBSOCKET_ENABLED=True
WEBSOCKET_RECONNECT_INTERVAL=5000

# Feature Flags (Phase 2)
FEATURE_WEBSOCKET_NOTIFICATIONS=True
FEATURE_ADVANCED_SEARCH=True
FEATURE_CALENDAR_VIEW=True
FEATURE_NOTIFICATION_CENTER=True 